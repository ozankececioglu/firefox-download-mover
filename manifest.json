{
  "manifest_version": 3,
  "name": "Download Mover",
  "version": "0.1.0",
  "description": "Move Firefox downloads into subfolders of your Downloads directory based on URL-matching rules.",
  "permissions": ["downloads", "storage"],
  "background": {
    "scripts": ["background.js"]
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "download-mover@local.dev",
      "strict_min_version": "115.0"
    }
  }
}
